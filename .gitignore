# Rain .gitignore -- whitelist mode

# Ignore everything
*

# Allow structure
!.gitignore
!.github/
!.github/workflows/
!.github/workflows/**
!CMakeLists.txt
!README.md
!README_EN.md

# Allow source
!src/
!src/*/
!src/**/*.hpp

# Allow tests
!test/
!test/*.cpp

# Allow benchmarks
!benchmark/
!benchmark/*.cpp
!benchmark/*.sh
!benchmark/tokio_echo/
!benchmark/tokio_echo/Cargo.toml
!benchmark/tokio_echo/src/
!benchmark/tokio_echo/src/*.rs

!LICENSE

!jekyll/
!jekyll/**

# Ignore generated and local Jekyll artifacts
jekyll/.bundle/
jekyll/.jekyll-cache/
jekyll/.sass-cache/
jekyll/.jekyll-metadata
jekyll/_site/
jekyll/vendor/
